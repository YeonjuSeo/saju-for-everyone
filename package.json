{
  "name": "saju-check",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Discover your Korean Saju Day Pillar (Ilju) — global K-Saju",
  "scripts": {
    "dev": "vite",
    "images": "node scripts/generate-image-manifest.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lunar-typescript": "1.8.6",
    "luxon": "3.7.2",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.4.8",
    "@vercel/node": "3.2.17",
    "@testing-library/react": "16.0.1",
    "@types/luxon": "3.4.2",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.1",
    "autoprefixer": "10.4.20",
    "jsdom": "25.0.0",
    "postcss": "8.4.45",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4",
    "vite": "5.4.3",
    "vitest": "2.0.5"
  }
}
