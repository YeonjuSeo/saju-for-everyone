# ── Client (optional) ─────────────────────────────────────────────
# Where the browser sends anonymous "result viewed" pings.
# Defaults to "/api/log" (the bundled Vercel function). Leave unset for that.
# VITE_LOG_ENDPOINT=/api/log

# ── Server: Google Sheets logging (all optional) ──────────────────
# If any of these are missing, /api/log silently does nothing — the site
# still works, it just won't record hits. NONE of this touches birth data.
#
# 1. Create a Google Cloud service account, enable the Google Sheets API.
# 2. Create a JSON key; copy the client_email and private_key below.
# 3. Create a Google Sheet, add a tab named "Hits", and SHARE the sheet
#    with the service-account email (Editor).
# 4. Put the sheet's ID (from its URL) in SHEET_ID.

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Paste the whole private key on one line, keeping the literal "\n" sequences.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# The long id in https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=your_sheet_id_here

# Optional. Tab + columns to append to. Default: Hits!A:C
# Columns written: [ISO timestamp, date (YYYY-MM-DD), country code]
SHEET_RANGE=Hits!A:C
